location                  = "koreacentral"
alert_resource_group_name = "rg-monitoring"

vm_name        = "vm-test01"
vm_resource_id = "/subscriptions/<subscription-id>/resourceGroups/<vm-rg>/providers/Microsoft.Compute/virtualMachines/vm-test01"

# Required for Available Memory Bytes platform alert calculation.
# Example: Standard_D2s_v3 = 8192 MB.
total_memory_mb = 8192

# Optional Action Group IDs.
action_group_ids = [
  # "/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.Insights/actionGroups/<action-group-name>"
]

enable_vm_insights_log_alerts = false

# Required only when enable_vm_insights_log_alerts = true.
log_analytics_workspace_id = null
